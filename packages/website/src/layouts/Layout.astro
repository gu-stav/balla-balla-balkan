---
import '../styles/global.css'
import { getSettings } from '../utils/settings';
import Header from '../components/Header.astro';
import Player from '../components/Player.svelte';
import { getImage } from 'astro:assets';
import Analytics from '@vercel/analytics/astro'
import  SpeedInsights  from "@vercel/speed-insights/astro"

const settings = await getSettings();
const { title, description, image } = Astro.props

const ogImage = image ? image : settings.ogImageFallback ? `${settings?.ogImageFallback}?h=630&w=1280` : undefined;
const ogImageOptimized = ogImage ? await getImage({ src: ogImage, format: 'webp', width: 1280, height: 630 }) : undefined;

const twitterImage = image ? image : settings.ogImageFallback ? `${settings?.ogImageFallback}?h=675&w=1200` : undefined;
const twitterImageOptimized = twitterImage ? await getImage({ src: twitterImage, format: 'png', width: 1200, height: 675 }) : undefined;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />

        <title>{title ? `${title} | ` : ''} {settings?.title}</title>
        <meta name="description" content={description ?? settings?.description} />

        <meta property="og:type" content="website" />
        <meta name="og:title" content={title ? `${title} | ${settings?.title}` : settings?.title} />
        <meta name="og:description" content={description ?? settings?.description} />
        {ogImageOptimized && <meta name="og:image" content={ogImageOptimized.src} />}

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title ? `${title} | ${settings?.title}` : settings?.title} />
        <meta name="twitter:description" content={description ?? settings?.description} />
        {twitterImageOptimized && <meta name="twitter:image" content={twitterImageOptimized.src} />}

		<meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" href="/favicon.svg" sizes="392x392" type="image/svg+xml" />
	</head>

	<body class="bg-gray flex flex-col gap-4 sm:gap-10 min-h-screen">
        <Header />

        <main class="flex flex-col items-center w-full">
          <slot />
        </main>

        <footer class="bg-red flex justify-center p-3 -mt-4 sm:-mt-10">
            <nav class="flex flex-col sm:flex-row gap-3 sm:gap-20 max-w-3xl">
                <div class="flex gap-8 justify-center">
                    <a class="font-medium text-white hover:underline" href="/impressum">Impressum</a>
                    <a class="font-medium text-white hover:underline" href="/datenschutzerklaerung">Datenschutz</a>
                    <a class="font-medium text-white hover:underline" href="/unterstuetzen">Unterstützen</a>
                </div>

                <div class="flex gap-8 justify-center">
                    <a class="flex font-medium items-center text-white hover:underline gap-2" href="https://bsky.app/profile/ballaballa-balkan.bsky.social">
                        <svg class="w-5 h-5" viewBox="0 0 600 530" version="1.1" xmlns="http://www.w3.org/2000/svg">
                            <path d="m135.72 44.03c66.496 49.921 138.02 151.14 164.28 205.46 26.262-54.316 97.782-155.54 164.28-205.46 47.98-36.021 125.72-63.892 125.72 24.795 0 17.712-10.155 148.79-16.111 170.07-20.703 73.984-96.144 92.854-163.25 81.433 117.3 19.964 147.14 86.092 82.697 152.22-122.39 125.59-175.91-31.511-189.63-71.766-2.514-7.3797-3.6904-10.832-3.7077-7.8964-0.0174-2.9357-1.1937 0.51669-3.7077 7.8964-13.714 40.255-67.233 197.36-189.63 71.766-64.444-66.128-34.605-132.26 82.697-152.22-67.108 11.421-142.55-7.4491-163.25-81.433-5.9562-21.282-16.111-152.36-16.111-170.07 0-88.687 77.742-60.816 125.72-24.795z" class="fill-white" />
                        </svg>
                        Bluesky</a>
                    <a class="flex font-medium items-center text-white hover:underline gap-2" href="https://www.instagram.com/neuesvomballaballabalkan1">
                        <svg class="w-5 h-5" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M7.0301.084c-1.2768.0602-2.1487.264-2.911.5634-.7888.3075-1.4575.72-2.1228 1.3877-.6652.6677-1.075 1.3368-1.3802 2.127-.2954.7638-.4956 1.6365-.552 2.914-.0564 1.2775-.0689 1.6882-.0626 4.947.0062 3.2586.0206 3.6671.0825 4.9473.061 1.2765.264 2.1482.5635 2.9107.308.7889.72 1.4573 1.388 2.1228.6679.6655 1.3365 1.0743 2.1285 1.38.7632.295 1.6361.4961 2.9134.552 1.2773.056 1.6884.069 4.9462.0627 3.2578-.0062 3.668-.0207 4.9478-.0814 1.28-.0607 2.147-.2652 2.9098-.5633.7889-.3086 1.4578-.72 2.1228-1.3881.665-.6682 1.0745-1.3378 1.3795-2.1284.2957-.7632.4966-1.636.552-2.9124.056-1.2809.0692-1.6898.063-4.948-.0063-3.2583-.021-3.6668-.0817-4.9465-.0607-1.2797-.264-2.1487-.5633-2.9117-.3084-.7889-.72-1.4568-1.3876-2.1228C21.2982 1.33 20.628.9208 19.8378.6165 19.074.321 18.2017.1197 16.9244.0645 15.6471.0093 15.236-.005 11.977.0014 8.718.0076 8.31.0215 7.0301.0839m.1402 21.6932c-1.17-.0509-1.8053-.2453-2.2287-.408-.5606-.216-.96-.4771-1.3819-.895-.422-.4178-.6811-.8186-.9-1.378-.1644-.4234-.3624-1.058-.4171-2.228-.0595-1.2645-.072-1.6442-.079-4.848-.007-3.2037.0053-3.583.0607-4.848.05-1.169.2456-1.805.408-2.2282.216-.5613.4762-.96.895-1.3816.4188-.4217.8184-.6814 1.3783-.9003.423-.1651 1.0575-.3614 2.227-.4171 1.2655-.06 1.6447-.072 4.848-.079 3.2033-.007 3.5835.005 4.8495.0608 1.169.0508 1.8053.2445 2.228.408.5608.216.96.4754 1.3816.895.4217.4194.6816.8176.9005 1.3787.1653.4217.3617 1.056.4169 2.2263.0602 1.2655.0739 1.645.0796 4.848.0058 3.203-.0055 3.5834-.061 4.848-.051 1.17-.245 1.8055-.408 2.2294-.216.5604-.4763.96-.8954 1.3814-.419.4215-.8181.6811-1.3783.9-.4224.1649-1.0577.3617-2.2262.4174-1.2656.0595-1.6448.072-4.8493.079-3.2045.007-3.5825-.006-4.848-.0608M16.953 5.5864A1.44 1.44 0 1 0 18.39 4.144a1.44 1.44 0 0 0-1.437 1.4424M5.8385 12.012c.0067 3.4032 2.7706 6.1557 6.173 6.1493 3.4026-.0065 6.157-2.7701 6.1506-6.1733-.0065-3.4032-2.771-6.1565-6.174-6.1498-3.403.0067-6.156 2.771-6.1496 6.1738M8 12.0077a4 4 0 1 1 4.008 3.9921A3.9996 3.9996 0 0 1 8 12.0077" class="fill-white"/>
                        </svg>
                        Instagram</a>
                </div>
            </nav>

            <Player client:load />
            <Analytics />
            <SpeedInsights />
        </footer>
	</body>
</html>
